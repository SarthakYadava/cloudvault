AWS_PROFILE=file-java90
AWS_REGION=eu-north-1
S3_BUCKET=file-java90
# Absolute path to the directory containing your AWS config and credentials.
# Windows example: C:/Users/your-name/.aws
# Linux/macOS example: /home/your-name/.aws
AWS_CREDENTIALS_DIR=C:/Users/your-name/.aws

JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRATION=PT1H
PRESIGNED_URL_EXPIRATION=PT10M

DB_USERNAME=cloudvault
DB_PASSWORD=replace-with-a-strong-database-password
